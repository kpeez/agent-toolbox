{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "if": "Edit(*.py)", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/format-python.sh" },
          { "type": "command", "if": "Write(*.py)", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/format-python.sh" },
          { "type": "command", "if": "MultiEdit(*.py)", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/format-python.sh" }
        ]
      }
    ]
  }
}
