{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '(.tool_input.file_path // \"\") + \"\\n\" + (.tool_input.command // \"\")' | grep -q 'specs/' && python3 \"${CLAUDE_PLUGIN_ROOT}\"/skills/spec/scripts/spec_status.py --write --quiet 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
